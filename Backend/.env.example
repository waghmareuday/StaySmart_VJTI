# Backend runtime configuration
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/staysmart
JWT_SECRET=replace_with_a_strong_secret
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# SMTP configuration (required for dues/attendance emails)
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
CHIEF_WARDEN_EMAIL=chiefwarden@vjti.ac.in

# Admin credentials (required for admin login)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin

# Seed helper default password (optional)
TEST_STUDENT_DEFAULT_PASSWORD=student123
